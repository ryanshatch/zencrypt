# Flask runtime
FLASK_ENV=production
FLASK_APP=webapp.py
DEBUG=False

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<required_random_secret>
JWT_SECRET_KEY=<required_random_secret>

# SQLite example path (keep file outside static/public folders)
SQLALCHEMY_DATABASE_URI=sqlite:////var/data/zencrypt/zencrypt.db

# Optional hardening knobs
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
MAX_CONTENT_LENGTH=16777216
